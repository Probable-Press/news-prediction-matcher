# Copy this file to .env and fill in your keys.
# .env is git-ignored — never commit secrets.

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Personal Access Token (repo + workflow スコープ)
# 取得: https://github.com/settings/tokens
# GitHub Secrets への登録名: PAT
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# Dune Analytics API Key (オンチェーン大口取引分析 / reports用)
# 取得: https://dune.com → Settings → API Keys → New Key
# GitHub Secrets への登録名: DUNE_API_KEY
DUNE_API_KEY=

# Dune クエリID (src/fetch_dune.py のコメントのSQLでクエリ作成後に設定)
# GitHub Secrets への登録名: DUNE_QUERY_ID
DUNE_QUERY_ID=

# Metaculus API Token (専門家コミュニティ予測 / 比較軸)
# 取得: https://www.metaculus.com → Profile → API Tokens
# GitHub Secrets への登録名: METACULUS_API_KEY
METACULUS_API_KEY=

# Guardian Open Platform API Key (構造化英語ニュース補強)
# 取得: https://open-platform.theguardian.com/access/
# GitHub Secrets への登録名: GUARDIAN_API_KEY
GUARDIAN_API_KEY=
