---
interface Props {
  title: string;
  description?: string;
  image?: string;
}
const { title, description = '予測市場でニュースを読む — Probable Press', image } = Astro.props;
const siteUrl = Astro.site ?? new URL('https://probable-press.pages.dev');
const imageUrl = image ? new URL(image, siteUrl).toString() : undefined;
---
<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  {imageUrl && <meta property="og:image" content={imageUrl} />}
  {imageUrl && <meta name="twitter:card" content="summary_large_image" />}
  <title>{title} | Probable Press</title>
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <header class="site-header">
    <a href="/" class="brand">Probable Press</a>
    <span class="tagline">予測市場でニュースを読む</span>
    <nav class="site-nav">
      <a href="/about">このサイトについて</a>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>© Probable Press · NHK × Polymarket Gap Analysis</p>
  </footer>
</body>
</html>
