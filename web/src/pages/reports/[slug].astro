---
import Base from '../../layouts/Base.astro';
import { marked } from 'marked';

export async function getStaticPaths() {
  const { readdir, readFile } = await import('node:fs/promises');
  const { resolve } = await import('node:path');
  const dir = resolve(process.cwd(), '../reports');
  const files = (await readdir(dir)).filter(f => f.endsWith('.md') && f !== '.gitkeep');
  return Promise.all(files.map(async (f) => {
    const slug = f.replace('.md', '');
    const raw = await readFile(resolve(dir, f), 'utf-8');
    return { params: { slug }, props: { raw } };
  }));
}

const { raw } = Astro.props;
const { slug } = Astro.params;
const html = await marked.parse(raw, { gfm: true });
const titleMatch = raw.match(/^#\s+(.+)/m);
const metaMatch = raw.match(/_Generated:\s*(.+?)_/);
const title = titleMatch ? titleMatch[1] : slug;
const meta = metaMatch ? metaMatch[1] : '';
---
<Base title={slug} description={`${slug}のNHK×Polymarketギャップ分析レポート`}>
  <div class="container">
    <a href="/" class="back-link">← 一覧に戻る</a>
    <div class="report-header">
      <h1>{title}</h1>
      {meta && <p class="report-meta">{meta}</p>}
    </div>
    <div class="report-body" set:html={html} />
  </div>
</Base>
